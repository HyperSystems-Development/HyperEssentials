$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 32, Bottom: 2);
  Background: (Color: #1a2a3a);
  Padding: (Left: 10, Right: 10, Top: 4, Bottom: 4);

  Label #PlayerName {
    Text: "Player";
    Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
    FlexWeight: 1;
  }

  TextButton #AddBtn {
    Text: "SHARE";
    Anchor: (Width: 70, Height: 24);
    Style: $S.@GreenButtonStyle;
  }
}
