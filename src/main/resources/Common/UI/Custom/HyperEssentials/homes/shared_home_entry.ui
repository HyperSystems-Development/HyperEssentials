$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 48, Bottom: 4);
  Background: (Color: #1a2a3a);
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);

  // Cyan indicator bar (shared branding)
  Group {
    Anchor: (Width: 3, Top: 4, Bottom: 4);
    Background: (Color: #55FFFF);
  }

  Group { Anchor: (Width: 8); }

  // Owner and home name
  Group {
    Anchor: (Width: 160);
    LayoutMode: Top;

    Label #HomeName {
      Text: "Home";
      Style: (FontSize: 13, TextColor: #FFFFFF, RenderBold: true, VerticalAlignment: Center);
      Anchor: (Height: 20);
    }

    Label #OwnerName {
      Text: "Shared by Player";
      Style: (FontSize: 10, TextColor: #55FFFF, VerticalAlignment: Center);
      Anchor: (Height: 16);
    }
  }

  // Cooldown info (hidden by default, shown when on cooldown)
  Label #HomeCooldown {
    Text: "";
    Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
    Anchor: (Width: 120);
    Visible: false;
  }

  // Coordinates (hidden when cooldown is showing)
  Label #HomeCoords {
    Text: "0, 0, 0";
    Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
    Anchor: (Width: 120);
  }

  Group { FlexWeight: 1; }

  // Teleport button
  TextButton #TeleportBtn {
    Text: "TP";
    Anchor: (Width: 50, Height: 28);
    Style: $S.@GoldButtonStyle;
  }
}
