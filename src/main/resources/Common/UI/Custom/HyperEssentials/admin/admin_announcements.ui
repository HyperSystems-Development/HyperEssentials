$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../shared/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperEssentialsNavBar #NavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 660, Height: 480);

    #Title {
      $C.@Title {
        @Text = "Announcements";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 15, Bottom: 15);

      // Info header
      Group {
        Anchor: (Height: 22, Bottom: 4);
        LayoutMode: Left;

        Label #MessageCount {
          Text: "0 announcements";
          Style: (FontSize: 13, TextColor: #CCCCCC, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 200);
        }

        Group { FlexWeight: 1; }

        Label #IntervalLabel {
          Text: "";
          Style: (FontSize: 11, TextColor: #666666, HorizontalAlignment: End, VerticalAlignment: Center);
          Anchor: (Width: 200);
        }
      }

      // Mode label
      Group {
        Anchor: (Height: 18, Bottom: 8);

        Label #ModeLabel {
          Text: "";
          Style: (FontSize: 11, TextColor: #FFAA00);
        }
      }

      // Gold divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #FFAA00);
      }

      // Scrollable content area
      Group #MessageListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #MessageList {
          LayoutMode: Top;
        }
      }

      // Pagination footer
      Group #PaginationRow {
        Anchor: (Height: 28, Top: 6);
        LayoutMode: Left;

        Group { FlexWeight: 1; }

        TextButton #PrevBtn {
          Text: "Prev";
          Style: $S.@ButtonStyle;
          Anchor: (Width: 60, Height: 24);
        }

        Group { Anchor: (Width: 8); }

        Label #PageInfo {
          Text: "Page 1 / 1";
          Style: (FontSize: 11, TextColor: #7c8b99, HorizontalAlignment: Center, VerticalAlignment: Center);
          Anchor: (Width: 80);
        }

        Group { Anchor: (Width: 8); }

        TextButton #NextBtn {
          Text: "Next";
          Style: $S.@ButtonStyle;
          Anchor: (Width: 60, Height: 24);
        }

        Group { FlexWeight: 1; }
      }
    }
  }
}

$C.@BackButton {}
