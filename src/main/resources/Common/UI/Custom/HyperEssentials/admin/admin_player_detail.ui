$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Padding: (Left: 4, Right: 4);

  // Player header
  Group {
    Anchor: (Height: 32, Bottom: 8);
    Background: (Color: #1a2a3a);
    Padding: (Left: 12, Top: 6, Bottom: 6);
    LayoutMode: Top;

    Label #DetailName {
      Text: "";
      Style: (FontSize: 14, TextColor: #FFAA00, RenderBold: true, VerticalAlignment: Center);
      Anchor: (Height: 18);
    }
  }

  // Stats section
  Group #DetailStats {
    LayoutMode: Top;
    Padding: (Left: 4, Right: 4, Bottom: 8);
  }

  // Divider
  Group {
    Anchor: (Height: 1, Bottom: 8);
    Background: (Color: #2a3a4a);
  }

  // Action buttons row
  Group #DetailActions {
    LayoutMode: Left;
    Anchor: (Height: 30);
    Padding: (Left: 4, Right: 4);

    TextButton #KickBtn {
      Text: "Kick";
      Style: $S.@GoldButtonStyle;
      Anchor: (Width: 70, Height: 26);
    }

    // Spacer
    Group { Anchor: (Width: 8); }

    TextButton #MuteBtn {
      Text: "Mute";
      Style: $S.@RedButtonStyle;
      Anchor: (Width: 70, Height: 26);
    }

    // Spacer
    Group { Anchor: (Width: 8); }

    TextButton #BanBtn {
      Text: "Ban";
      Style: $S.@FlatRedButtonStyle;
      Anchor: (Width: 70, Height: 26);
    }
  }
}
