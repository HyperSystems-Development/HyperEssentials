$S = "../shared/styles.ui";

Group {
  Anchor: (Height: 50, Bottom: 3);
  Background: (Color: #1a2a3a);
  LayoutMode: Left;

  // Type indicator bar
  Group #TypeBar {
    Anchor: (Width: 3, Height: 50);
    Background: (Color: #FF5555);
  }

  // Info section
  Group {
    FlexWeight: 1;
    Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
    LayoutMode: Top;

    Group {
      Anchor: (Height: 18);
      LayoutMode: Left;

      Label #TypeBadge {
        Text: "BAN";
        Style: (FontSize: 10, TextColor: #FF5555, RenderBold: true, VerticalAlignment: Center);
        Anchor: (Width: 50);
      }

      Label #PlayerName {
        Text: "";
        Style: (FontSize: 13, TextColor: #FFFFFF, RenderBold: true, VerticalAlignment: Center);
        Anchor: (Width: 120);
      }

      Label #IssuerName {
        Text: "";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 120);
      }
    }

    Group {
      Anchor: (Height: 14);
      LayoutMode: Left;

      Label #Reason {
        Text: "";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        Anchor: (Width: 250);
      }

      Label #Expires {
        Text: "";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 100);
      }
    }
  }

  // Revoke button
  Group {
    Anchor: (Width: 85);
    Padding: (Right: 10, Top: 13, Bottom: 13);

    TextButton #RevokeBtn {
      Text: "Revoke";
      Style: $S.@FlatRedButtonStyle;
      Anchor: (Width: 70, Height: 26);
    }
  }
}
