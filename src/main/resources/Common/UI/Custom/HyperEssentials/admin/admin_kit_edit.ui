$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Padding: (Left: 4, Right: 4);

  // Back button row
  Group {
    Anchor: (Height: 28, Bottom: 6);
    LayoutMode: Left;

    TextButton #EditBackBtn {
      Text: "Back";
      Style: $S.@ButtonStyle;
      Anchor: (Width: 70, Height: 24);
    }

    Group { Anchor: (Width: 10); }

    Label #EditTitle {
      Text: "Edit Kit";
      Style: (FontSize: 14, TextColor: #FFAA00, RenderBold: true, VerticalAlignment: Center);
      Anchor: (Height: 24);
    }
  }

  // Divider
  Group {
    Anchor: (Height: 1, Bottom: 10);
    Background: (Color: #2a3a4a);
  }

  // Name (read-only)
  Group {
    Anchor: (Height: 22, Bottom: 4);
    LayoutMode: Left;

    Label {
      Text: "Name:";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    Label #EditName {
      Text: "";
      Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Display Name
  Group {
    Anchor: (Height: 28, Bottom: 4);
    LayoutMode: Left;

    Label #EditDisplayNameLabel {
      Text: "Display Name:";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    $C.@TextField #EditDisplayName {
      Anchor: (Height: 26);
      Style: (FontSize: 12, TextColor: #ffffff);
      FlexWeight: 1;
    }
  }

  // Cooldown
  Group {
    Anchor: (Height: 28, Bottom: 4);
    LayoutMode: Left;

    Label #EditCooldownLabel {
      Text: "Cooldown (sec):";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    $C.@TextField #EditCooldown {
      Anchor: (Width: 100, Height: 26);
      Style: (FontSize: 12, TextColor: #ffffff);
    }
  }

  // One-time toggle
  Group {
    Anchor: (Height: 28, Bottom: 4);
    LayoutMode: Left;

    Label {
      Text: "One-time:";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    TextButton #EditOneTimeToggle {
      Text: "No";
      Style: $S.@ButtonStyle;
      Anchor: (Width: 80, Height: 24);
    }
  }

  // Permission
  Group {
    Anchor: (Height: 28, Bottom: 4);
    LayoutMode: Left;

    Label #EditPermissionLabel {
      Text: "Permission:";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    $C.@TextField #EditPermission {
      Anchor: (Height: 26);
      Style: (FontSize: 12, TextColor: #ffffff);
      FlexWeight: 1;
    }
  }

  // Items count (read-only info)
  Group {
    Anchor: (Height: 22, Bottom: 10);
    LayoutMode: Left;

    Label {
      Text: "Items:";
      Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 110);
    }

    Label #EditItemCount {
      Text: "0";
      Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Divider
  Group {
    Anchor: (Height: 1, Bottom: 10);
    Background: (Color: #2a3a4a);
  }

  // Save / Cancel buttons
  Group {
    LayoutMode: Left;
    Anchor: (Height: 30);

    Group { FlexWeight: 1; }

    TextButton #EditCancelBtn {
      Text: "Cancel";
      Style: $S.@ButtonStyle;
      Anchor: (Width: 90, Height: 28);
    }

    Group { Anchor: (Width: 10); }

    TextButton #EditSaveBtn {
      Text: "Save";
      Style: $S.@FlatGreenButtonStyle;
      Anchor: (Width: 90, Height: 28);
    }

    Group { FlexWeight: 1; }
  }
}
