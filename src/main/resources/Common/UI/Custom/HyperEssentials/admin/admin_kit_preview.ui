$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Padding: (Left: 8, Right: 8);

  // Header row with back button and title
  Group {
    Anchor: (Height: 32, Bottom: 8);
    LayoutMode: Left;

    TextButton #PreviewBackBtn {
      Text: "Back";
      Style: $S.@ButtonStyle;
      Anchor: (Width: 75, Height: 28);
    }

    Group { Anchor: (Width: 12); }

    Label #PreviewTitle {
      Text: "Kit Preview";
      Style: (FontSize: 14, TextColor: #FFAA00, RenderBold: true, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Kit metadata row
  Group {
    Anchor: (Height: 20, Bottom: 6);
    LayoutMode: Left;

    Label #PreviewCooldown {
      Text: "";
      Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
      Anchor: (Width: 120);
    }

    Label #PreviewOneTime {
      Text: "";
      Style: (FontSize: 10, TextColor: #FFAA00, VerticalAlignment: Center);
      Anchor: (Width: 80);
    }

    Label #PreviewPermission {
      Text: "";
      Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Gold divider
  Group {
    Anchor: (Height: 1, Bottom: 8);
    Background: (Color: #FFAA00);
  }

  // Item count
  Label #PreviewItemCount {
    Text: "0 items";
    Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
    Anchor: (Height: 18, Bottom: 6);
  }

  // Scrollable items list
  Group #PreviewItemsContainer {
    LayoutMode: TopScrolling;
    ScrollbarStyle: $C.@DefaultScrollbarStyle;
    FlexWeight: 1;

    Group #PreviewItems {
      LayoutMode: Top;
    }
  }
}
