$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Padding: (Left: 4, Right: 4);

  // Back button row
  Group {
    Anchor: (Height: 28, Bottom: 6);
    LayoutMode: Left;

    TextButton #PreviewBackBtn {
      Text: "Back";
      Style: $S.@ButtonStyle;
      Anchor: (Width: 70, Height: 24);
    }

    Group { Anchor: (Width: 10); }

    Label #PreviewTitle {
      Text: "Kit Preview";
      Style: (FontSize: 14, TextColor: #FFAA00, RenderBold: true, VerticalAlignment: Center);
      Anchor: (Height: 24);
    }
  }

  // Kit metadata row
  Group {
    Anchor: (Height: 18, Bottom: 4);
    LayoutMode: Left;

    Label #PreviewCooldown {
      Text: "";
      Style: (FontSize: 10, TextColor: #7c8b99, VerticalAlignment: Center);
      Anchor: (Width: 120);
    }

    Label #PreviewOneTime {
      Text: "";
      Style: (FontSize: 10, TextColor: #FFAA00, VerticalAlignment: Center);
      Anchor: (Width: 80);
    }

    Label #PreviewPermission {
      Text: "";
      Style: (FontSize: 10, TextColor: #7c8b99, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Divider
  Group {
    Anchor: (Height: 1, Bottom: 6);
    Background: (Color: #2a3a4a);
  }

  // Item count
  Label #PreviewItemCount {
    Text: "0 items";
    Style: (FontSize: 11, TextColor: #7c8b99, VerticalAlignment: Center);
    Anchor: (Height: 16, Bottom: 4);
  }

  // Scrollable items list
  Group #PreviewItemsContainer {
    LayoutMode: TopScrolling;
    ScrollbarStyle: $C.@DefaultScrollbarStyle;
    FlexWeight: 1;

    Group #PreviewItems {
      LayoutMode: Top;
    }
  }
}
