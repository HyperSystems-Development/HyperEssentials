$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../shared/nav_bar.ui";

@ConfigTab = MenuItem {
  Padding: (Left: 10, Right: 10);
  Style: (
    Default: (
      LabelStyle: (FontSize: 11, TextColor: #7c8b99, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)
    ),
    Hovered: (
      Background: #121a26,
      LabelStyle: (FontSize: 11, TextColor: #FFAA00, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)
    )
  );
  SelectedStyle: (
    Default: (
      LabelStyle: (FontSize: 11, TextColor: #FFAA00, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)
    ),
    Hovered: (
      Background: #121a26,
      LabelStyle: (FontSize: 11, TextColor: #FFAA00, VerticalAlignment: Center, RenderUppercase: true, RenderBold: true)
    )
  );
};

$C.@PageOverlay {
  $Nav.@HyperEssentialsNavBar #NavBar {}

  Group #TabBar {
    LayoutMode: Left;
    Background: #0d1520;
    Anchor: (Height: 34, Top: 45);
    Padding: (Left: 6);

    @ConfigTab #TabCore { Text: "Core"; }
    @ConfigTab #TabHomes { Text: "Homes"; }
    @ConfigTab #TabWarps { Text: "Warps"; }
    @ConfigTab #TabSpawns { Text: "Spawns"; }
    @ConfigTab #TabTeleport { Text: "Teleport"; }
    @ConfigTab #TabWarmup { Text: "Warmup"; }
    @ConfigTab #TabKits { Text: "Kits"; }
    @ConfigTab #TabModeration { Text: "Moderation"; }
    @ConfigTab #TabVanish { Text: "Vanish"; }
    @ConfigTab #TabUtility { Text: "Utility"; }
    @ConfigTab #TabAnnouncements { Text: "Announce"; }
    @ConfigTab #TabDebug { Text: "Debug"; }
    @ConfigTab #TabBackup { Text: "Backup"; }
  }

  $C.@DecoratedContainer {
    Anchor: (Width: 780, Height: 640);

    #Title {
      Group {
        LayoutMode: Left;
        Padding: (Left: 15, Right: 15);

        $C.@Title #PageTitle {
          @Text = "Config: Core";
        }

        Group { FlexWeight: 1; }

        Label #StatusLabel {
          Text: "No changes";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 180, Height: 30);
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 10, Right: 10, Top: 4, Bottom: 2);

      Group {
        FlexWeight: 1;
        LayoutMode: Left;
        Padding: (Top: 2, Bottom: 2);

        Group #LeftColumn {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 2, Right: 6, Top: 2, Bottom: 2);

          Group #LeftContainer {
            LayoutMode: Top;
          }
        }

        Group #RightColumn {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 6, Right: 2, Top: 2, Bottom: 2);

          Group #RightContainer {
            LayoutMode: Top;
          }
        }
      }

      Group #ActionBar {
        LayoutMode: Left;
        Anchor: (Height: 40);

        TextButton #ResetBtn {
          Style: $S.@RedButtonStyle;
          Text: "Reset Defaults";
          Anchor: (Width: 150, Height: 32);
        }

        Group { FlexWeight: 1; }

        TextButton #ReloadBtn {
          Style: $S.@GoldButtonStyle;
          Text: "Reload";
          Anchor: (Width: 90, Height: 32);
        }

        Group { Anchor: (Width: 8); }

        TextButton #RevertBtn {
          Style: $S.@ButtonStyle;
          Text: "Revert";
          Anchor: (Width: 100, Height: 32);
        }

        Group { Anchor: (Width: 8); }

        TextButton #SaveBtn {
          Style: $S.@CyanButtonStyle;
          Text: "Save";
          Anchor: (Width: 100, Height: 32);
        }
      }
    }
  }
}

$C.@BackButton {}
