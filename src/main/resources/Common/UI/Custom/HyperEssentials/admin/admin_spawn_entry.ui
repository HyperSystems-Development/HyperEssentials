$S = "../shared/styles.ui";

Group {
  Anchor: (Height: 44, Bottom: 3);
  Background: (Color: #1a2a3a);
  LayoutMode: Left;

  // Color indicator bar
  Group #IndicatorBar {
    Anchor: (Width: 3, Height: 44);
    Background: (Color: #FFAA00);
  }

  // Info section
  Group {
    FlexWeight: 1;
    Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
    LayoutMode: Top;

    Group {
      Anchor: (Height: 18);
      LayoutMode: Left;

      Label #SpawnName {
        Text: "";
        Style: (FontSize: 13, TextColor: #FFFFFF, RenderBold: true, VerticalAlignment: Center);
        Anchor: (Width: 150);
      }

      Label #DefaultBadge {
        Text: "";
        Style: (FontSize: 10, TextColor: #55FF55, RenderBold: true, VerticalAlignment: Center);
        Anchor: (Width: 80);
      }
    }

    Group {
      Anchor: (Height: 14);
      LayoutMode: Left;

      Label #SpawnWorld {
        Text: "";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 100);
      }

      Label #SpawnCoords {
        Text: "";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 180);
      }
    }
  }

  // Action buttons
  Group {
    Anchor: (Width: 220);
    Padding: (Right: 10, Top: 10, Bottom: 10);
    LayoutMode: Left;

    TextButton #TpBtn {
      Text: "TP";
      Style: $S.@CyanButtonStyle;
      Anchor: (Width: 40, Height: 26);
    }

    Group { Anchor: (Width: 6); }

    TextButton #SetGlobalBtn {
      Text: "Set Global";
      Style: $S.@GoldButtonStyle;
      Anchor: (Width: 85, Height: 26);
    }

    Group { Anchor: (Width: 6); }

    TextButton #DeleteBtn {
      Text: "Delete";
      Style: $S.@RedButtonStyle;
      Anchor: (Width: 70, Height: 26);
    }
  }
}
