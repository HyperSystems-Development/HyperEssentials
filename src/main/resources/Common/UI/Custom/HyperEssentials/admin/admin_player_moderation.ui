$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../shared/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperEssentialsNavBar #NavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 640, Height: 480);

    #Title {
      $C.@Title {
        @Text = "Player Moderation";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 15, Bottom: 15);

      // Header row with back button, search, and count
      Group #HeaderRow {
        Anchor: (Height: 32, Bottom: 8);
        LayoutMode: Left;

        TextButton #BackBtn {
          Text: "Back";
          Style: $S.@ButtonStyle;
          Anchor: (Width: 70, Height: 28);
        }

        Group { Anchor: (Width: 8); }

        Group {
          Anchor: (Width: 200, Height: 28);
          Background: (Color: #0d1520);
          Padding: (Left: 8, Right: 8);

          $C.@TextField #SearchInput {
            Anchor: (Height: 24);
            Style: (FontSize: 11, TextColor: #CCCCCC);
          }
        }

        Group { Anchor: (Width: 8); }

        TextButton #SearchBtn {
          Text: "Search";
          Style: $S.@GoldButtonStyle;
          Anchor: (Width: 75, Height: 28);
        }

        Group { FlexWeight: 1; }

        Label #StatusLabel {
          Text: "";
          Style: (FontSize: 11, TextColor: #666666, VerticalAlignment: Center);
          Anchor: (Width: 150);
        }
      }

      // Gold divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #FFAA00);
      }

      // Main content area (scrollable)
      Group #ContentArea {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #ContentList {
          LayoutMode: Top;
        }
      }
    }
  }
}

$C.@BackButton {}
