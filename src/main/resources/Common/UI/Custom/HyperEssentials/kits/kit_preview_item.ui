$C = "../../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 36, Bottom: 2);
  Background: (Color: #1a2a3a);
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

  // Item icon
  ItemIcon #ItemIconEl {
    Anchor: (Width: 28, Height: 28);
  }

  Group { Anchor: (Width: 8); }

  // Item name
  Label #ItemName {
    Text: "Item";
    Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
    Anchor: (Width: 200);
  }

  Group { FlexWeight: 1; }

  // Quantity
  Label #ItemQty {
    Text: "x1";
    Style: (FontSize: 12, TextColor: #7c8b99, VerticalAlignment: Center, HorizontalAlignment: Center);
    Anchor: (Width: 40);
  }

  // Section label
  Label #ItemSection {
    Text: "";
    Style: (FontSize: 10, TextColor: #555555, VerticalAlignment: Center, HorizontalAlignment: Center);
    Anchor: (Width: 60);
  }
}
