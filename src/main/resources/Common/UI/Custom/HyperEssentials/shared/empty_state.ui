$C = "../../Common.ui";
$S = "styles.ui";

Group {
    LayoutMode: Top;
    Padding: (Full: 30);

    Label #EmptyTitle {
        Text: "Nothing here";
        Anchor: (Height: 24);
        Style: (
            FontSize: 16;
            TextColor: $S.@ColorGray;
            HorizontalAlignment: Center;
        );
    };

    Label #EmptyMessage {
        Text: "No items to display.";
        Anchor: (Height: 18, Top: 6);
        Style: (
            FontSize: 13;
            TextColor: $S.@ColorMuted;
            HorizontalAlignment: Center;
        );
    };
};
